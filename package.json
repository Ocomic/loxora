{
  "name": "loxora",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.7.0",
  "engines": {
    "node": ">=24.18.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run build",
    "clean": "tsc -b --clean",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "test": "npm run build && node --test packages/core/dist/test/boundary.test.js packages/sqlite/dist/test/lifecycle.test.js",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@types/node": "24.5.2",
    "typescript": "5.9.2"
  }
}
