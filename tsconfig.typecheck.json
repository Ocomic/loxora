{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@loxora/core": ["packages/core/src/index.ts"],
      "@loxora/sqlite": ["packages/sqlite/src/index.ts"],
      "@loxora/mcp": ["packages/mcp/src/index.ts"],
      "@loxora/demo": ["packages/demo/src/index.ts"]
    },
    "jsx": "react-jsx"
  },
  "include": ["packages/*/src/**/*.ts", "packages/*/src/**/*.tsx", "packages/*/test/**/*.ts"]
}
